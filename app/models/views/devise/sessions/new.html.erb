<div class="rt-auth-wrap">
  <div class="rt-auth-side">
    <h2>Entrar</h2>
    <p class="rt-auth-sub">Bem-vindo de volta</p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="rt-auth-form">
        <div class="rt-field">
          <%= f.label :email %>
          <%= f.input_field :email, required: false, autofocus: true, input_html: { autocomplete: "email" }, placeholder: "seu@email.com", class: "" %>
        </div>
        <div class="rt-field">
          <%= f.label :password %>
          <%= f.input_field :password, required: false, input_html: { autocomplete: "current-password" }, placeholder: "••••••••", class: "" %>
        </div>
        <% if devise_mapping.rememberable? %>
          <div class="rt-checkbox">
            <%= f.input_field :remember_me, as: :boolean %>
            <%= f.label :remember_me, "Lembrar de mim" %>
          </div>
        <% end %>
        <%= f.button :submit, "Entrar", class: "rt-submit" %>
      </div>
    <% end %>

    <div class="rt-auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
