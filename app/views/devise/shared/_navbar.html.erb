<nav class="rt-nav">
  <%= link_to root_path, class: "rt-logo" do %>
    <span class="rt-logo-icon">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="17" cy="5" r="2.5" fill="#ff4d00"/>
        <path d="M10 10.5L13.5 8.5L16 12.5L13 15L14.5 20H18L20 24H16L14 19L10.5 20.5H8L10 14.5L7.5 13L10 10.5Z" fill="#ff4d00"/>
        <path d="M6 23.5L8.5 22" stroke="#ff4d00" stroke-width="2" stroke-linecap="round"/>
        <path d="M17.5 20.5L20 23" stroke="#ff4d00" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </span>
    RUN TOGETHER
  <% end %>

  <ul class="rt-links">
    <li><%= link_to "Explorar Corridas", runs_path, class: current_page?(runs_path) ? "active" : "" %></li>

    <% if user_signed_in? %>
      <li><%= link_to "Minhas Corridas", my_runs_path, class: current_page?(my_runs_path) ? "active" : "" %></li>
      <li><%= link_to "Participando", participating_runs_path, class: current_page?(participating_runs_path) ? "active" : "" %></li>
      <li><%= link_to "Mensagens", chats_path, class: current_page?(chats_path) ? "active" : "" %></li>
      <li><%= link_to "+ Criar Corrida", new_run_path, class: "rt-cta" %></li>
    <% end %>
  </ul>

  <div class="rt-user">
    <% if user_signed_in? %>
      <div class="rt-dropdown" id="rtDropdown">
        <div class="rt-avatar" id="avatarBtn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="8" r="4" fill="#ff4d00"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="#ff4d00" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="rt-avatar-initials">
            <%= current_user.name&.split&.map { |n| n[0] }&.first(2)&.join&.upcase %>
          </span>
        </div>
        <div class="rt-dropdown-menu" id="dropdownMenu">
          <%= link_to "Meu Perfil", edit_user_registration_path, class: "rt-dropdown-item" %>
          <%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete }, class: "rt-dropdown-item rt-dropdown-logout" %>
        </div>
      </div>
    <% else %>
      <%= link_to "Entrar", new_user_session_path, class: "rt-login" %>
      <%= link_to "Cadastrar", new_user_registration_path, class: "rt-cta" %>
    <% end %>
  </div>
</nav>

<script>
  (function() {
    function initDropdown() {
      const btn = document.getElementById('avatarBtn');
      const menu = document.getElementById('dropdownMenu');
      if (!btn || !menu) return;

      btn.onclick = function(e) {
        e.stopPropagation();
        menu.classList.toggle('open');
      };

      document.onclick = function() {
        menu.classList.remove('open');
      };
    }

    document.addEventListener('turbo:load', initDropdown);
    document.addEventListener('DOMContentLoaded', initDropdown);
  })();
</script>
