<div class="chat-window">
  <div class="chat-header">
    <div class="chat-header-left">
      <%= link_to chats_path, class: "chat-back" do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      <% end %>
      <div class="chat-avatar">
        <%= @chat.other_user(current_user).name&.split&.map { |n| n[0] }&.first(2)&.join&.upcase %>
      </div>
      <div class="chat-header-info">
        <span class="chat-header-name"><%= @chat.other_user(current_user).name %></span>
        <span class="chat-header-status">Online</span>
      </div>
    </div>
  </div>

  <div class="chat-messages" id="chat-messages">
    <% @messages.each do |message| %>
      <div class="chat-bubble <%= message.user == current_user ? 'mine' : 'theirs' %>">
        <p><%= message.content %></p>
        <span class="chat-time"><%= message.created_at.strftime("%H:%M") %></span>
      </div>
    <% end %>
  </div>

  <%= form_with model: [@chat, @message], class: "chat-form" do |f| %>
    <%= f.text_field :content, placeholder: "Escreva uma mensagem...", class: "chat-input", autocomplete: "off" %>
    <button type="submit" class="chat-send">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  <% end %>
</div>
