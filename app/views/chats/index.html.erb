<div class="chats-index">
  <h2>Mensagens</h2>

  <div class="chats-tabs">
    <button class="chats-tab active" data-tab="all" onclick="switchTab('all')">Todas</button>
    <button class="chats-tab" data-tab="direct" onclick="switchTab('direct')">Individuais</button>
    <button class="chats-tab" data-tab="group" onclick="switchTab('group')">Grupos</button>
  </div>

  <% if @chats.empty? %>
    <p class="no-chats">Nenhuma conversa ainda.</p>
  <% else %>
    <div class="chat-list">
      <% @chats.each do |chat| %>
        <% if chat.group? %>
          <%= link_to chat_path(chat), class: "chat-item chat-item-group", data: { chat_type: "group" } do %>
            <div class="chat-avatar chat-avatar-group">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ff4d00" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <div class="chat-info">
              <span class="chat-name"><%= chat.run.location.truncate(30) %></span>
              <span class="chat-preview">
                <span class="chat-group-badge">Grupo</span>
                <%= chat.messages.last&.content&.truncate(30) || "Nenhuma mensagem ainda" %>
              </span>
            </div>
          <% end %>
        <% else %>
          <% other = chat.other_user(current_user) %>
          <%= link_to chat_path(chat), class: "chat-item", data: { chat_type: "direct" } do %>
            <div class="chat-avatar">
              <%= other.name&.split&.map { |n| n[0] }&.first(2)&.join&.upcase %>
            </div>
            <div class="chat-info">
              <span class="chat-name"><%= other.name %></span>
              <span class="chat-preview"><%= chat.messages.last&.content&.truncate(40) %></span>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<script>
  function switchTab(tab) {
    document.querySelectorAll('.chats-tab').forEach(t => t.classList.remove('active'));
    document.querySelector(`.chats-tab[data-tab="${tab}"]`).classList.add('active');

    document.querySelectorAll('.chat-item').forEach(item => {
      if (tab === 'all') {
        item.style.display = 'flex';
      } else {
        item.style.display = item.dataset.chatType === tab ? 'flex' : 'none';
      }
    });
  }
</script>
