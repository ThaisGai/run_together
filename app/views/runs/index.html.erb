<div class="runs-index">
  <h1>Explorar Corridas</h1>

  <% if @runs.empty? %>
    <p class="no-chats">Nenhuma corrida disponível no momento.</p>
  <% else %>
    <div class="runs-list">
      <% @runs.each do |run| %>
        <div class="run-card">
          <div class="run-card-header">
            <div class="run-creator-avatar">
              <%= run.user.name&.split&.map { |n| n[0] }&.first(2)&.join&.upcase %>
            </div>
            <div class="run-creator-info">
              <span class="run-creator-name"><%= run.user.name %></span>
              <span class="run-date"><%= run.date.strftime("%d/%m/%Y") %> às <%= run.time.strftime("%H:%M") %></span>
            </div>
          </div>

          <div class="run-card-body">
            <p class="run-location">📍 <%= run.location %></p>
            <p class="run-pace">⚡ Pace: <%= run.pace %></p>
          </div>

          <div class="run-card-actions">
            <%= link_to "Ver detalhes", run_path(run), class: "run-btn-outline" %>
            <%= link_to "Mensagem", chat_with_user_path(user_id: run.user.id), class: "rt-cta" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
