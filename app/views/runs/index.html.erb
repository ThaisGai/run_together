<div>
  <%= form_with url: runs_path, method: :get, class: "d-flex" do %>
    <%= label_tag :query, "Search runs", class: "visually-hidden" %>
    <%= text_field_tag :query,
          params[:query],
          class: "form-control",
          placeholder: "Type a keyword"
      %>
    <%= submit_tag "Search", name: "", class: "btn btn-primary" %>
  <% end %>
</div>
<div>

<h1>Runs</h1>

  <div
    id="map"
    data-markers="<%= @markers.to_json %>"
    data-mapbox-api-key="<%= ENV['MAPBOX_ACCESS_TOKEN'] %>"
    style="width: 100%; height: 500px;">
  </div>

  <script>
    const mapElement = document.getElementById("map")

    const markers = JSON.parse(mapElement.dataset.markers)
    const apiKey = mapElement.dataset.mapboxApiKey

    mapboxgl.accessToken = apiKey

    const map = new mapboxgl.Map({
      container: "map",
      style: "mapbox://styles/mapbox/streets-v12",
      zoom: 10
    })

    const bounds = new mapboxgl.LngLatBounds()

    markers.forEach((marker) => {
      const newMarker = new mapboxgl.Marker()
        .setLngLat([marker.lng, marker.lat])
        .addTo(map)

      bounds.extend([marker.lng, marker.lat])
    })

    map.fitBounds(bounds, { padding: 70, maxZoom: 15 })
  </script>

      <% @runs.each do |run| %>
        <div>
          <p><strong>Date:</strong> <%= run.date %></p>
          <p><strong>Time:</strong> <%= run.time.strftime("%H:%M") %></p>
          <p><strong>Location:</strong> <%= run.location %></p>
          <p><strong>Pace:</strong> <%= run.pace %></p>

          <%= link_to "View", run_path(run) %>

          <% if user_signed_in? && run.user != current_user %>
            <%= link_to "Mensagem", chat_path(run.user), class: "rt-cta" %>
          <% end %>

          <% if user_signed_in? && run.user == current_user %>
            <%= link_to "Delete", run_path(run), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
          <% end %>
        </div>
      <% end %>
