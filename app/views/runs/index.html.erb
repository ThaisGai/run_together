<div>
  <%= form_with url: runs_path, method: :get, class: "d-flex" do %>
    <%= label_tag :query, "Search runs", class: "visually-hidden" %>
    <%= text_field_tag :query,
          params[:query],
          class: "form-control",
          placeholder: "Type a keyword"
      %>
    <%= submit_tag "Search", name: "", class: "btn btn-primary" %>
  <% end %>
</div>
<div>

<div class="runs-index">
  <h1>Explorar Corridas</h1>

  <% if @runs.empty? %>
    <p class="no-chats">Você ainda não criou nenhuma corrida.</p>
    <%= link_to "+ Criar Corrida", new_run_path, class: "rt-cta" %>
  <% else %>
    <div class="runs-list">
      <% @runs.each do |run| %>
        <div class="run-card">
          <div class="run-card-header">
            <div class="run-creator-avatar">
              <%= current_user.name&.split&.map { |n| n[0] }&.first(2)&.join&.upcase %>
            </div>
            <div class="run-creator-info">
              <span class="run-creator-name"><%= current_user.name %></span>
              <span class="run-date"><%= run.date.strftime("%d/%m/%Y") %> às <%= run.time.strftime("%H:%M") %></span>
            </div>
          </div>

          <div class="run-card-body">
            <p class="run-location">📍

              <div
              id="map"
              data-markers="<%= @markers.to_json %>"
              data-mapbox-api-key="<%= ENV['MAPBOX_ACCESS_TOKEN'] %>"
              style="width: 100%; height:160px; border-radius:8px; overflow:hidden; margin-bottom:8px">
              </div>

              <script>
                const mapElement = document.getElementById("map")

                const markers = JSON.parse(mapElement.dataset.markers)
                const apiKey = mapElement.dataset.mapboxApiKey

                mapboxgl.accessToken = apiKey

                const map = new mapboxgl.Map({
                  container: "map",
                  style: "mapbox://styles/mapbox/streets-v12",
                  zoom: 10
                })

                const bounds = new mapboxgl.LngLatBounds()

                markers.forEach((marker) => {
                  const newMarker = new mapboxgl.Marker()
                    .setLngLat([marker.lng, marker.lat])
                    .addTo(map)

                  bounds.extend([marker.lng, marker.lat])
                })

                map.fitBounds(bounds, { padding: 70, maxZoom: 15 })
              </script>


            </p>
            <p class="run-pace">⚡ Pace: <%= run.pace %></p>
          </div>

          <div class="run-card-actions">
            <%= link_to "Ver detalhes", run_path(run), class: "run-btn-outline" %>
            <%= link_to "Editar", edit_run_path(run), class: "run-btn-outline" %>
            <%= button_to "Excluir", run, method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "run-btn-danger" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
