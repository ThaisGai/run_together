<div class="run-show-page">
  <div class="run-show-card">
    <div class="run-show-header">
      <div class="run-creator-avatar">
        <%= @run.user.name&.split&.map { |n| n[0] }&.first(2)&.join&.upcase %>
      </div>
      <div class="run-creator-info">
        <span class="run-creator-name"><%= @run.user.name %></span>
        <span class="run-date"><%= @run.date.strftime("%d/%m/%Y") %> às <%= @run.time.strftime("%H:%M") %></span>
      </div>
    </div>

    <div class="run-show-body">
      <p class="run-location">📍 <%= @run.location %></p>
      <% if @run.pace.present? %>
        <p class="run-pace">⚡ Pace: <%= @run.pace %></p>
      <% end %>
    </div>

    <div class="run-show-actions">
      <% if user_signed_in? %>
        <% if @run.user == current_user %>
          <%= link_to "Editar", edit_run_path(@run), class: "run-btn-outline" %>
          <%= link_to "Deletar", run_path(@run), data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" }, class: "run-btn-danger" %>
        <% else %>
          <%= link_to "Enviar mensagem ao criador", chat_with_user_path(user_id: @run.user.id), class: "run-btn-outline" %>
          <% if @run.members.include?(current_user) %>
            <span class="run-joined">✓ Você está participando!</span>
          <% else %>
            <%= button_to "Participar", run_run_members_path(@run), class: "rt-cta" %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @run.user == current_user %>
    <div class="run-members-section">
      <h3>Participantes</h3>
      <% if @run.members.any? %>
        <div class="run-members-list">
          <% @run.members.each do |member| %>
            <div class="run-member-item">
              <div class="run-creator-avatar">
                <%= member.name&.split&.map { |n| n[0] }&.first(2)&.join&.upcase %>
              </div>
              <span class="run-creator-name"><%= member.name %></span>
              <%= link_to "Mensagem", chat_with_user_path(user_id: member.id), class: "run-btn-outline" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="no-chats">Nenhum participante ainda.</p>
      <% end %>
    </div>
  <% end %>
</div>
