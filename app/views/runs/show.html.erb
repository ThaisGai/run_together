<div class="run-show-page">
  <div class="run-show-card">
    <div class="run-accent"></div>
    <div class="run-show-content">
      <div class="run-show-header">
        <div class="run-creator-avatar">
          <%= @run.user.name&.split&.map { |n| n[0] }&.first(2)&.join&.upcase %>
        </div>
        <div class="run-creator-info">
          <span class="run-creator-name"><%= @run.user.name %></span>
          <span class="run-date"><%= @run.date.strftime("%d/%m/%Y") %> às <%= @run.time.strftime("%H:%M") %></span>
        </div>
      </div>

      <div class="run-show-body">
        <div class="run-detail-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ff4d00" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <%= link_to @run.location, "https://www.google.com/maps?q=#{@run.latitude},#{@run.longitude}", target: "_blank", class: "run-location-link" %>
        </div>
        <% if @run.pace.present? %>
          <div class="run-detail-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ff4d00" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            <span>Pace: <%= @run.pace %></span>
          </div>
        <% end %>
        <div class="run-detail-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ff4d00" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          <span><%= @run.members.count %> participante<%= @run.members.count != 1 ? "s" : "" %></span>
        </div>
      </div>

      <div class="run-show-actions">
        <% if user_signed_in? %>
          <% if @run.user == current_user %>
            <%= link_to "Editar", edit_run_path(@run), class: "run-btn-outline" %>
            <%= link_to "Deletar", run_path(@run), data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" }, class: "run-btn-danger" %>
            <%= link_to "Chat da corrida", chat_path(@run.chat), class: "run-btn-primary" %>
          <% else %>
            <%= link_to "Enviar mensagem", chat_with_user_path(user_id: @run.user.id), class: "run-btn-outline" %>
            <% if @run.members.include?(current_user) %>
              <span class="run-joined">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                Participando
              </span>
              <%= button_to "Desistir", run_run_member_path(@run, @run.run_members.find_by(user: current_user)), method: :delete, data: { turbo_confirm: "Tem certeza que deseja sair desta corrida?" }, class: "run-btn-danger" %>
            <% else %>
              <%= button_to "Participar", run_run_members_path(@run), class: "run-btn-primary" %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @run.user == current_user %>
    <div class="run-members-section">
      <h3>Participantes</h3>
      <% if @run.members.any? %>
        <div class="run-members-list">
          <% @run.members.each do |member| %>
            <div class="run-member-item">
              <div class="run-creator-avatar">
                <%= member.name&.split&.map { |n| n[0] }&.first(2)&.join&.upcase %>
              </div>
              <span class="run-creator-name"><%= member.name %></span>
              <%= link_to "Mensagem", chat_with_user_path(user_id: member.id), class: "run-btn-outline" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="runs-empty">Nenhum participante ainda.</p>
      <% end %>
    </div>
  <% end %>
</div>
